{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/cron/reset-scores",
      "schedule": "1 4 * * *"
    },
    {
      "path": "/api/cron/generate-daily",
      "schedule": "1 0 * * *"
    }
  ]
}
